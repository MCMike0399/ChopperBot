# --- Required ---

# Discord bot token from the Developer Portal (https://discord.com/developers).
DISCORD_TOKEN=your-bot-token-from-developer-portal

# Discord snowflake (17–20 digits) of the channel that will run the
# `configuration` capability — the admin console where you bind other
# channels to other capabilities. The bot fails to boot without this.
CHOPPERBOT_CONFIG_CHANNEL_ID=000000000000000000

# Text brain selector: `kimi` (default) runs ALL text on Moonshot Kimi 2.7
# Thinking; `bedrock` runs text on Amazon Bedrock Converse (BEDROCK_MODEL_ID)
# using the ambient AWS credential chain — for AWS-native deploys (ECS) where
# no external LLM API key exists. Images ALWAYS go to Bedrock Nova Lite either
# way.
# LLM_TEXT_BACKEND=kimi

# Moonshot Kimi — the text brain for EVERY text domain (Discord chat, calendar/
# config tool-calling, event-intake, IG caption fallback), via the OpenAI-
# compatible chat-completions API. REQUIRED when LLM_TEXT_BACKEND=kimi (boot
# fails without it); unused in bedrock mode. Model is Kimi 2.7 Thinking
# (text-only; images are routed to Amazon Nova Lite on Bedrock — see below).
KIMI_API_KEY=sk-...
# Optional Kimi overrides (defaults shown). The coding endpoint gates on a
# coding-agent User-Agent; claude-cli/1.0.0 is on the allowlist. For the plain
# platform API use KIMI_BASE_URL=https://api.moonshot.ai/v1 + KIMI_MODEL_ID=kimi-k2-thinking.
# KIMI_BASE_URL=https://api.kimi.com/coding/v1
# KIMI_MODEL_ID=kimi-for-coding
# KIMI_USER_AGENT=claude-cli/1.0.0

# AWS credentials for Amazon Bedrock (Converse API). On the Pi these serve the
# IMAGES-ONLY backend: Kimi is text-only, so the only thing Bedrock serves is
# vision (the IG classifier's main call, or a chat message with an attached
# image) via Amazon Nova Lite.
# OPTIONAL — leave BOTH unset to use the AWS default credential chain instead
# (ECS task role, EC2 instance profile, or AWS_PROFILE locally); that is how
# the AWS-native (ECS) deploy authenticates. Set BOTH or neither. The var names
# are deliberately the short ACCESS_KEY_ID / SECRET_ACCESS_KEY (NOT the AWS_-
# prefixed standard names) so they don't collide with ambient AWS CLI creds.
#
# Gotcha: dotenv defaults to `override: false`, so a stale `export
# ACCESS_KEY_ID=...` in your shell rc will shadow this file. If auth fails as if
# the key is wrong, run `unset ACCESS_KEY_ID SECRET_ACCESS_KEY` in your shell.
# ACCESS_KEY_ID=
# SECRET_ACCESS_KEY=

# --- Optional ---

# A second seed channel that will route to DEFAULT_CAPABILITY on first
# boot. After the bot is running, live channel→capability bindings are
# managed from chat via the configuration capability.
# DISCORD_CHANNEL_ID=

# Bedrock region + vision model. Default region us-east-1. Bedrock serves ONLY
# image turns (Kimi handles all text). BEDROCK_MODEL_LOW is the single vision
# model (effort `low`), default Amazon Nova Lite — MUST be image-capable.
# BEDROCK_MODEL_ID is legacy (the old text model, off every hot path; kept for
# the dev smoke/bake-off scripts and an all-Bedrock rollback).
# Directive (2026-07-13): Nova only for images; it is `low`; medium+high are Kimi.
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# BEDROCK_MODEL_LOW=us.amazon.nova-lite-v1:0
# AWS_SESSION_TOKEN=          # only for temporary STS credentials

# Token / iteration caps for the multi-turn agent loop.
# MAX_OUTPUT_TOKENS=4096
# MAX_TOOL_ITERATIONS=10

# LOG_LEVEL=info

# Caps for Discord image attachments forwarded to Kimi as vision input.
# kimi-for-coding DOES accept images (png/jpeg/gif/webp) — verified live.
# Only documents (PDF/csv/docx) are unsupported; they're skipped with a
# warning, as are files over the size cap or beyond the count cap.
# MAX_ATTACHMENT_BYTES=10485760   # per-file cap, default 10 MB
# MAX_ATTACHMENT_COUNT=5          # max attachments per message, default 5

# Capability used when a channel has no explicit binding yet.
# DEFAULT_CAPABILITY=calendar

# Seed channel->capability bindings at first boot (priority order; after the
# first boot these only SEED — the DB, managed live from the configuration
# channel, is the source of truth). Prefer DISCORD_CHANNEL_CAPABILITIES.
#   1. DISCORD_CHANNEL_CAPABILITIES — JSON array of guilds, each with a list of
#      { id, capability } channels:
# DISCORD_CHANNEL_CAPABILITIES=[{"guildName":"My Server","channels":[{"id":"000000000000000000","capability":"calendar"},{"id":"111111111111111111","capability":"instagram_monitor"}]}]
#   2. DISCORD_AUTHORIZED_CHANNELS — legacy: JSON array of guilds; every listed
#      channel runs DEFAULT_CAPABILITY.
# DISCORD_AUTHORIZED_CHANNELS=[{"guildName":"My Server","channels":["000000000000000000"]}]

# Output channel for the calendar capability — where rendered month PDFs/PNGs
# and the master ICS are published. Distinct from the INPUT channel (bound to
# `calendar` via the normal routing table, where mods talk to the bot).
# Optional: seeds the calendar's DB setting on first boot; after that the DB
# value wins (change it from the config channel via `config_calendar`).
# CALENDAR_OUTPUT_CHANNEL_ID=000000000000000000

# Channel where release notes are published by `pnpm run release <version>`.
# This is a DEV-SIDE script (not a runtime capability), so the value is read
# straight from the environment — it is NOT part of the Zod config schema. If
# unset, the script falls back to its hardcoded default channel.
# RELEASE_NOTES_CHANNEL_ID=000000000000000000

# --- Instagram monitor (optional) ---
# When IG_SESSIONID + IG_CSRFTOKEN + IG_DS_USER_ID are ALL set, the fetcher
# authenticates (logged-in cookies + x-csrftoken), which gets far higher rate
# limits than anonymous requests. Without them it falls back to the public,
# heavily-throttled endpoint. Automated polling carries real ban risk — see
# the guardrail/anti-detection notes in CLAUDE.md. IG_MID / IG_DID are optional
# extras. Refresh these from the SAME browser as IG_USER_AGENT when the log
# shows `instagram_monitor.auth.expired`, then rebuild + restart.
# IG_SESSIONID=
# IG_CSRFTOKEN=
# IG_DS_USER_ID=
# IG_MID=
# IG_DID=

# User-Agent sent on every IG API and CDN request. SHOULD match the browser the
# session cookies were extracted from — a mismatched UA is a fingerprint signal.
# Unset = built-in desktop-Chrome default.
# IG_USER_AGENT=

# Hard ceiling on outbound IG HTTP calls in a rolling 24h window (one poll
# ~1.7 calls steady-state). On hit, polling soft-pauses (auto-recovers as the
# window drains) and the config channel is alerted. The adaptive budget
# governor keeps steady-state spend under this, so it should rarely trip.
# IG_DAILY_REQUEST_BUDGET=120

# ── Event intake from the ticket funnel (event_intake capability) ────────────
# Passive: reads the Ticket Tool event-request form in ticket channels, posts a
# normalized + conflict-checked proposal, and creates the calendar event when a
# MODERATOR approves by talking to the bot in the ticket. Not in the routing
# table (like file_scanner). Optional — with no category set it simply idles.
#
# Ticket CATEGORY ids to watch (JSON array or comma/space list). Also accepts
# `guild:<serverId>` and `all`. Seeds the DB on first boot; DB wins after
# (manage live from the config channel via `config_eventintake`).
# EVENT_INTAKE_TICKET_CATEGORY_IDS=1436254735677128714
#
# Who may APPROVE (→ create the event). Role ids (deterministic, preferred) or
# role NAMES; comma list or JSON array. Empty = the built-in default
# Moderador/Administrador/Administradora ids + anyone with Administrator perm.
# EVENT_INTAKE_MOD_ROLES=Moderador, Administrador, Administradora
#
# The ticket bot whose form messages are parsed (default: Ticket Tool).
# EVENT_INTAKE_TICKET_BOT_ID=557628352828014614

# --- Sancus Ops copilot (sancus_ops capability, all optional) ---
# AWS named profile for the CloudWatch Logs Insights client. Default `sancus`
# (self-hosted runs as burbujamc). Set to the literal `default` to use the AWS
# default credential chain (ECS task role / instance profile) — the ECS deploy.
# SANCUS_OPS_AWS_PROFILE=sancus
# Region of the Nautilus log groups (pinned us-east-2).
# SANCUS_OPS_AWS_REGION=us-east-2
# Environments the copilot may query (dev,qa,prod).
# SANCUS_OPS_NAUTILUS_ENVS=dev,qa,prod
# Read-only GitHub token for the `github` tool (falls back to `gh auth token`).
# GITHUB_TOKEN=
