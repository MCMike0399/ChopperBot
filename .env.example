# --- Required ---

# Discord bot token from the Developer Portal (https://discord.com/developers).
DISCORD_TOKEN=your-bot-token-from-developer-portal

# Discord snowflake (17–20 digits) of the channel that will run the
# `configuration` capability — the admin console where you bind other
# channels to other capabilities. The bot fails to boot without this.
CHOPPERBOT_CONFIG_CHANNEL_ID=000000000000000000

# Kimi Code API key (sk-kimi-...). Created in the Kimi Code Console at
# https://www.kimi.com/code/console. REQUIRED — the bot fails to boot
# without it.
#
# Gotcha: dotenv defaults to `override: false`, so a stale `export
# KIMI_API_KEY=...` in your shell rc will shadow this file. If the bot
# behaves as if the key is wrong, run `unset KIMI_API_KEY` in your shell.
KIMI_API_KEY=sk-kimi-your-key-here

# --- Optional ---

# A second seed channel that will route to DEFAULT_CAPABILITY on first
# boot. After the bot is running, live channel→capability bindings are
# managed from chat via the configuration capability.
# DISCORD_CHANNEL_ID=

# Defaults for the Kimi client. Override only if your subscription URL,
# model, or required User-Agent differ.
# KIMI_BASE_URL=https://api.kimi.com/coding/v1
# KIMI_MODEL_ID=kimi-for-coding
# KIMI_USER_AGENT=claude-cli/1.0.0

# Token / iteration caps for the multi-turn agent loop.
# MAX_OUTPUT_TOKENS=4096
# MAX_TOOL_ITERATIONS=10

# LOG_LEVEL=info

# Caps for Discord image attachments forwarded to Kimi as vision input.
# kimi-for-coding DOES accept images (png/jpeg/gif/webp) — verified live.
# Only documents (PDF/csv/docx) are unsupported; they're skipped with a
# warning, as are files over the size cap or beyond the count cap.
# MAX_ATTACHMENT_BYTES=10485760   # per-file cap, default 10 MB
# MAX_ATTACHMENT_COUNT=5          # max attachments per message, default 5

# Capability used when a channel has no explicit binding yet.
# DEFAULT_CAPABILITY=calendar
